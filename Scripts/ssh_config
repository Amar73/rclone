# =============================================================================
# ~/.ssh/config — Конфигурация SSH-клиента
# =============================================================================
#
# КАК ЧИТАТЬ ЭТОТ ФАЙЛ:
#   SSH читает блоки сверху вниз. Для каждого подключения применяется
#   ПЕРВЫЙ подходящий параметр, дальнейшие блоки уточняют, но не
#   перезаписывают уже установленное. Поэтому глобальные настройки
#   (Host *) размещают В КОНЦЕ файла — они действуют как "умолчания".
#
# СТРУКТУРА ИНФРАСТРУКТУРЫ:
#
#   [localhost]
#       │
#       ├──► github.com          (прямое подключение, ключ id_ed25519)
#       │
#       └──► amar224             (шлюз-бастион)
#                │
#                ├──► wn75       (промежуточный сервер)
#                │       │
#                │       └──► arch03, arch04, arch05  (архивные серверы)
#                │
#                └──► ui         (сервис на нестандартном порту 7890)
#                        │
#                        └──► archminio01, archminio02  (MinIO-серверы)
#
# =============================================================================


# =============================================================================
# GITHUB — прямое подключение для работы с репозиториями
# =============================================================================
Host github.com
    # Явно указываем хост — здесь это одно и то же, но для других алиасов
    # вроде "gh" → "github.com" это поле было бы другим
    HostName github.com

    # Git использует SSH с пользователем "git" — это стандарт GitHub/GitLab/Gitea
    User git

    # ИСПРАВЛЕНО: было "IdentityAgent none" — это не то же самое, что
    # "не использовать агента". Правильный способ отключить агент для хоста
    # — явно задать путь к ключу через IdentityFile и запретить агента.
    #
    # IdentityAgent none — говорит SSH не обращаться к агенту вообще.
    # Это полезно: GitHub не нуждается в agent forwarding, и так мы
    # изолируем ключ от других хостов.
    IdentityAgent none
    IdentityFile ~/.ssh/id_ed25519


# =============================================================================
# AMAR224 — основной шлюз (бастион), точка входа в инфраструктуру
# =============================================================================
Host amar224
    # ЗАМЕЧАНИЕ: "amar" — короткое имя без домена. Это работает только если:
    #   а) запись есть в /etc/hosts: "192.168.x.x amar"
    #   б) mDNS (Avahi/Bonjour) резолвит "amar.local"
    #   в) настроен search domain в /etc/resolv.conf
    #
    # РЕКОМЕНДАЦИЯ: укажите явный IP или FQDN для надёжности:
    #   HostName 192.168.1.100   ← так подключение работает везде
    HostName amar

    User amar

    # ИСПРАВЛЕНО: было "IdentityAgent ~/.ssh/id_ed25519" — это ОШИБКА.
    #
    # IdentityAgent принимает путь к UNIX-сокету агента, например:
    #   IdentityAgent $SSH_AUTH_SOCK        ← системный агент
    #   IdentityAgent ~/.gnupg/S.gpg-agent.ssh  ← gpg-agent
    #   IdentityAgent /run/user/1000/gnupg/...  ← явный путь к сокету
    #
    # Путь к файлу ключа (id_ed25519) здесь не работает — SSH попытается
    # подключиться к нему как к сокету и получит ошибку.
    #
    # Правильная директива для указания ключа — IdentityFile:
    IdentityFile ~/.ssh/id_ed25519

    # Добавляем ключ в ssh-agent автоматически при первом использовании.
    # Это избавляет от необходимости запускать ssh-add вручную.
    # Работает совместно с глобальным "AddKeysToAgent yes" в блоке Host *
    AddKeysToAgent yes


# =============================================================================
# WN75 — промежуточный сервер, доступный через amar224
# =============================================================================
Host wn75
    HostName wn75
    # ЗАМЕЧАНИЕ по безопасности: подключение под root — опасная практика.
    #
    # При компрометации SSH-ключа злоумышленник получает полный root-доступ
    # к серверу без каких-либо дополнительных барьеров (sudo, пароль и т.д.).
    #
    # РЕКОМЕНДАЦИЯ: создайте обычного пользователя на сервере и используйте
    # sudo для привилегированных операций:
    #   User deploy       ← непривилегированный пользователь
    #   (на сервере: usermod -aG sudo deploy)
    #   (затем: ssh wn75 "sudo systemctl restart nginx")
    User root

    # ProxyJump — современный способ прыжков через бастионы (OpenSSH 7.3+).
    # Заменяет устаревший ProxyCommand. SSH автоматически:
    #   1. Подключается к amar224
    #   2. Через него открывает TCP-туннель до wn75
    #   3. Выполняет SSH-рукопожатие с wn75
    #
    # Альтернативная запись через запятую для цепочки прыжков:
    #   ProxyJump user@jump1,user@jump2
    ProxyJump amar224


# =============================================================================
# ARCH03, ARCH04, ARCH05 — архивные серверы через wn75
# =============================================================================
# Группировка нескольких хостов в одном блоке — правильный подход,
# позволяет не дублировать настройки для каждого сервера отдельно
Host arch03 arch04 arch05
    # %h — подстановка текущего Host-алиаса (arch03, arch04 или arch05).
    # Здесь HostName совпадает с псевдонимом, поэтому %h — краткая запись.
    # Если реальные имена отличались бы, пришлось бы делать отдельные блоки.
    HostName %h

    # ЗАМЕЧАНИЕ: та же проблема с root, что и у wn75 (см. выше)
    User root

    # Цепочка прыжков: localhost → amar224 → wn75 → arch0X
    # Три звена — много для надёжности. При нестабильном соединении
    # любой из трёх узлов может разорвать цепочку.
    # ConnectTimeout и ServerAliveInterval в блоке Host * помогают
    # быстрее обнаруживать разрывы
    ProxyJump wn75


# =============================================================================
# UI — сервис на нестандартном порту, доступный через amar224
# =============================================================================
Host ui
    HostName ui
    User amar

    # Нестандартный порт явно задан в конфиге — не нужно помнить
    # и каждый раз писать "ssh -p 7890 ui"
    Port 7890

    ProxyJump amar224


# =============================================================================
# ARCHMINIO01, ARCHMINIO02 — MinIO-серверы через ui
# =============================================================================
# Цепочка: localhost → amar224 → ui(:7890) → archminio0X
Host archminio01 archminio02
    HostName %h
    User amar
    ProxyJump ui


# =============================================================================
# ГЛОБАЛЬНЫЕ НАСТРОЙКИ — применяются ко всем хостам как умолчания
# =============================================================================
# ВАЖНО: блок Host * должен быть В КОНЦЕ файла.
# SSH применяет первый найденный параметр; если поставить Host * в начало,
# его значения будут перекрывать индивидуальные настройки хостов выше.
Host *
    # Автоматически добавлять ключ в ssh-agent при первом использовании.
    # Без этого нужно вручную запускать: ssh-add ~/.ssh/id_ed25519
    # Работает только если запущен ssh-agent или gpg-agent
    AddKeysToAgent yes

    # Keepalive: отправлять "пустые" пакеты каждые 60 секунд,
    # чтобы сессия не зависала при простое (брандмауэры и NAT
    # обрывают незамкнутые соединения через ~2–5 минут молчания).
    # Особенно важно для длинных цепочек ProxyJump
    ServerAliveInterval 60

    # Если сервер не ответил на 3 keepalive-пакета подряд (3 × 60с = 3 мин),
    # SSH разрывает соединение. Без этого "мёртвая" сессия зависает навсегда
    ServerAliveCountMax 3

    # Максимальное время ожидания при установке соединения.
    # При многозвенных цепочках ProxyJump каждый прыжок добавляет задержку,
    # поэтому ставим 15 секунд вместо системного дефолта (~2 минуты)
    ConnectTimeout 15

    # Сжатие трафика — полезно на медленных каналах и длинных цепочках.
    # На быстрых локальных сетях незначительно влияет на производительность
    Compression yes

    # Хранить мастер-соединение и переиспользовать его для новых сессий
    # к тому же хосту. Последующие ssh/scp/rsync подключаются мгновенно,
    # не тратя время на TLS-рукопожатие повторно.
    # Особенно ускоряет работу с цепочками ProxyJump
    ControlMaster auto
    ControlPath ~/.ssh/ctrl-%r@%h:%p
    ControlPersist 10m
